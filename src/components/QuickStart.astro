---
const steps = [
  {
    h: "Start (or enter) a git repository",
    p: "<code>git init my-app && cd my-app</code>",
  },
  {
    h: "Bootstrap everything",
    p: "<code>sopsy init</code> — tools check, Secure Enclave identity, config files.",
  },
  {
    h: "Put real secrets in",
    p: "<code>sopsy edit .env.encrypted</code> decrypts to your editor and re-encrypts on save.",
  },
  {
    h: "Verify hygiene before you commit",
    p: "<code>sopsy check</code> — the same command your CI runs.",
  },
  {
    h: "Commit the encrypted artifacts",
    p: "Plaintext <code>.env</code> is already gitignored. Push the ciphertext with confidence.",
  },
  {
    h: "A teammate joins (self-service)",
    p: 'The new dev clones the repo and runs <code>sopsy join "Alan Turing"</code> — mints their own Secure Enclave key with Touch ID and records a <code>pending</code> request. They commit and open a PR.',
  },
  {
    h: "An existing member approves",
    p: 'Any current member runs <code>sopsy approve "Alan Turing"</code> — promotes the key into <code>.sops.yaml</code> and re-keys every secret. Now Alan can decrypt.',
  },
];
---

<section class="section" id="quickstart">
  <div class="container qs__wrap">
    <div data-reveal>
      <p class="eyebrow eyebrow--lime">Quick start</p>
      <h2 class="section-title">From zero to a whole team in seven steps.</h2>
      <ol class="steps">
        {
          steps.map((s) => (
            <li>
              <div>
                <h4>{s.h}</h4>
                <p>
                  <Fragment set:html={s.p} />
                </p>
              </div>
            </li>
          ))
        }
      </ol>
    </div>

    <div data-reveal>
      <h3 class="qs__cast-title">Watch the entire process live just below…</h3>
      <!-- asciinema recording goes here — drop the <iframe> inside .qs__cast -->
      <div class="qs__cast">
        <h3 class="qs__cast-hint amber">
          Asciinema Recording of the entire process is coming soon...
        </h3>
      </div>
    </div>
  </div>
</section>
