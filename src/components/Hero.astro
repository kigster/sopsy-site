---
// Two install paths — Homebrew first (the recommended, prebuilt route).
const installs = ["brew install kigster/tap/sopsy", "cargo install sopsy"];
// Each terminal line gets an incremental reveal delay. A condensed,
// faithful run of `sopsy init` — the age key is truncated to keep the
// terminal from scrolling horizontally.
const lines = [
  { c: "prompt", t: "sopsy init" },
  { c: "cmt", t: "  bootstrapping your encrypted repository" },
  { c: "ok", t: "  ✔ git repository   ✔ found sops" },
  { c: "cmt", t: "  > Generate a Secure Enclave identity?  Yes" },
  { c: "ok", t: "  ✔ created Secure Enclave identity (Touch ID)" },
  { c: "cmt", t: "  ℹ private key never leaves the Enclave" },
  { c: "key", t: "  ➜ public recipient  age1se1q2a48h0242huw4…" },
  { c: "cmt", t: "  > Your name (key owner):  Konstantin" },
  { c: "ok", t: "  ✔ .sops.yaml   ✔ .env.example   ✔ .env.encrypted" },
  { c: "ok", t: "  ✔ .gitignore   ✔ .sopsy.yml" },
  { c: "cmt", t: "  > Set up a break-glass emergency key?  Yes" },
  { c: "ok", t: "  ✔ wrote break-glass.private + .public" },
  { c: "warn", t: "  ⚠ store both offline in 1Password, then continue" },
  { c: "cmt", t: "  press ENTER once the keys are saved …" },
  { c: "ok", t: "  ✔ removed local key files" },
  { c: "ok", t: "  ✔ recorded break-glass in both config files" },
  { c: "ok", t: "  ✔ repository bootstrapped" },
];
---

<section class="hero">
  <div class="container">
    <p class="eyebrow hero__kicker" data-reveal>
      A CLI for SOPS · age · Apple Secure Enclave<br />YubiKey Linux Support
      Coming Soon
    </p>

    <h1 data-reveal>
      Encrypted <span class="swap">secrets</span> you can actually commit to <span
        class="swap">Git</span
      >.<br />
      <em>Decrypt with Touch ID</em>
    </h1>
    <br />
    <h2 class="subhead">No plaintext anywhere. Sleep soundly at night.</h2>

    <div class="hero__cols">
      <div data-reveal>
        <p class="hero__sub">
          <b>sopsy</b> encrypts the secrets in your <code>.env, .yml</code>, and <code
            >.json</code
          > files — values only, names left in the clear. The file stays diffable
          and git blame-able, so you can see exactly when each key appeared and who
          added it, then commit the whole thing without flinching. Every teammate's
          key is minted inside their&nbsp;
          <a
            class="highlight"
            href="https://support.apple.com/guide/security/the-secure-enclave-sec59b0b31ff/web"
            target="_blank">Mac's Secure Enclave</a
          >.&nbsp;
          <br /><br />

          Secrets decrypt only on Touch ID, the private key never leaves the
          chip, and any current member can grant the next one access. No server.
          No subscription. No plaintext in Slack — or anywhere for that matter.
        </p>

        <div class="hero__actions">
          <div class="hero__cmds">
            {
              installs.map((cmd) => (
                <div class="copyfield">
                  <span class="sigil">$</span>
                  <span>{cmd}</span>
                  <button data-copy={cmd} aria-label={`Copy: ${cmd}`}>
                    copy
                  </button>
                </div>
              ))
            }
          </div>
          <a class="btn btn--ghost" href="#quickstart"
            >See the 60-second setup ↓</a
          >
        </div>
      </div>

      <div data-reveal>
        <div
          class="terminal"
          role="img"
          aria-label="Terminal showing 'sopsy init' bootstrapping a repository"
        >
          <div class="terminal__bar">
            <div class="terminal__dots"><i></i><i></i><i></i></div>
            <span class="terminal__title">~/my-app — sopsy</span>
          </div>
          <div class="terminal__body reveal-lines">
            {
              lines.map((l, i) => (
                <span
                  class={`ln ${l.c}`}
                  style={`animation-delay:${i * 220 + 200}ms`}
                >
                  {l.t}
                </span>
              ))
            }
            <span
              class="ln prompt cursor"
              style={`animation-delay:${lines.length * 220 + 300}ms`}></span>
          </div>
        </div>

        <div class="hero__foot">
          <p class="hero__note">
            <span class="dot" aria-hidden="true"></span>
            Built on SOPS + age — the encryption tools teams already trust. sopsy
            just makes them delightful.
          </p>

          <div class="badges" aria-label="Project badges">
            <span class="badge">crate <b>v1.1</b></span>
            <span class="badge">CI <b class="lime">passing</b></span>
            <span class="badge">license <b>MIT / Apache-2.0</b></span>
            <span class="badge">🍎 <b>Apple Silicon</b></span>
            <span class="badge">key <b>never leaves the chip</b></span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
