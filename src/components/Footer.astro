---
const year = 2026;
---

<footer class="footer">
  <div class="container">
    <div class="footer__top">
      <div class="footer__col footer__about">
        <a href={import.meta.env.BASE_URL} class="brand"
          ><span class="glyph" aria-hidden="true">🔒</span>sopsy</a
        >
        <p>
          The missing developer experience for SOPS. A small, fast, colorful
          Rust CLI for hardware-protected secrets in Git.
        </p>
      </div>

      <div class="footer__col">
        <h5>Project</h5>
        <a
          href="https://github.com/kigster/sopsy"
          target="_blank"
          rel="noopener">GitHub repo</a
        >
        <a href="https://crates.io/crates/sopsy" target="_blank" rel="noopener"
          >crates.io</a
        >
        <a
          href="https://docs.rs/crate/sopsy/latest"
          target="_blank"
          rel="noopener">docs.rs</a
        >
      </div>

      <div class="footer__col">
        <h5>Docs</h5>
        <a
          href="https://github.com/kigster/sopsy/blob/main/docs/guide-member.md"
          target="_blank"
          rel="noopener">Member guide</a
        >
        <a
          href="https://github.com/kigster/sopsy/blob/main/docs/guide-owner.md"
          target="_blank"
          rel="noopener">Owner guide</a
        >
        <a href="#quickstart">Quick start</a>
      </div>

      <div class="footer__col">
        <h5>Built on</h5>
        <a href="https://github.com/getsops/sops" target="_blank" rel="noopener"
          >SOPS</a
        >
        <a
          href="https://github.com/FiloSottile/age"
          target="_blank"
          rel="noopener">age</a
        >
        <a
          href="https://github.com/remko/age-plugin-se"
          target="_blank"
          rel="noopener">age-plugin-se</a
        >
      </div>
    </div>

    <div class="footer__bottom">
      <span>© {year} sopsy · MIT / Apache-2.0 · macOS-first (v1.1)</span>
      <span>
        Built by <a
          href="https://github.com/kigster"
          target="_blank"
          rel="noopener">@kigster</a
        >
        · sopsy orchestrates SOPS — it doesn't replace it.
      </span>
    </div>
  </div>
</footer>
