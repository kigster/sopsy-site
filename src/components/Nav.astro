---
const repo = 'https://github.com/kigster/sopsy';
const crate = 'https://crates.io/crates/sopsy';
---

<header class="nav">
  <div class="container nav__inner">
    <a href={import.meta.env.BASE_URL} class="brand" aria-label="sopsy home">
      <span class="glyph" aria-hidden="true">🔒</span>
      sopsy<small>v1 · macOS</small>
    </a>

    <nav class="nav__links" aria-label="Primary">
      <a href="#why">Why sopsy</a>
      <a href="#features">Features</a>
      <a href="#security">Security</a>
      <a href="#commands">Commands</a>
      <a href="#quickstart">Quick start</a>
    </nav>

    <div class="nav__cta">
      <a class="btn btn--ghost" href={crate} target="_blank" rel="noopener">crates.io ↗</a>
      <a class="btn btn--primary" href={repo} target="_blank" rel="noopener">GitHub ↗</a>
    </div>
  </div>
</header>
